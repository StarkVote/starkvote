# StarkVote Deployment Configuration
# Copy this file to .env and fill in your values

# Your Starknet wallet address
ACCOUNT_ADDRESS=0x...

# Your wallet's private key (keep this secret!)
PRIVATE_KEY=0x...

# RPC endpoint for Starknet Sepolia
# Public endpoints (may have rate limits for large contract declares):
#   https://starknet-sepolia-rpc.publicnode.com
# For deploying Groth16 verifier (~2MB), use a private RPC (e.g. Alchemy, Infura)
RPC_URL=https://starknet-sepolia-rpc.publicnode.com
