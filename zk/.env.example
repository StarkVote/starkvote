# StarkVote Deployment Configuration
# Copy this file to .env and fill in your values

# Your Starknet wallet address (the account that will be the admin)
ADMIN_ADDRESS=0x...

# Your wallet's private key (keep this secret!)
PRIVATE_KEY=0x...

# RPC endpoint (default is Sepolia testnet)
RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7
