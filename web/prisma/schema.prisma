generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id        String   @id @default(cuid())
  pollId    String
  question  String
  createdAt DateTime @default(now())

  @@index([pollId])
}
